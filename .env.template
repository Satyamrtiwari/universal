# --- Rural TeleHealth System Configuration Template ---
# Copy this file to .env and fill in your actual keys.
# DO NOT push your actual .env file to GitHub!

# [Django Settings]
SECRET_KEY=paste_your_django_secret_key_here
DEBUG=True

# [AI & LLM Services]
# Primary: Gemini, Backup: Groq
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Preferred LLM Provider: 'gemini' or 'groq'
LLM_PROVIDER=gemini
LLM_BACKUP_PROVIDER=groq

# [Video/Audio Consultation - Agora]
# Get these from: https://console.agora.io/
AGORA_APP_ID=your_agora_app_id_here
AGORA_APP_CERTIFICATE=your_agora_certificate_here

# [Video/Audio Consultation - Jitsi]
JITSI_DOMAIN=meet.jit.si

# [Internal URLs]
FASTAPI_URL=http://localhost:8000
BACKEND_URL=http://localhost:8080

# [Notifications]
WHATSAPP_API_KEY=your_whatsapp_key_here
ENABLE_OFFLINE_SYNC=True
